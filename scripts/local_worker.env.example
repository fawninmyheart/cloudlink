# Cloudlink local worker configuration.
# Copy this file to scripts/local_worker.env and edit values as needed.

# Public Cloudlink API base URL. Local worker reaches the cloud through HTTPS.
CLOUD_API_BASE_URL=https://tasks.example.com

# Worker API secret. Dashboard-installed workers receive a node-specific secret
# during registration. Legacy/manual starts may leave this empty to let
# scripts/start_local_worker.sh fetch the fallback secret using WORKER_SECRET_SSH_HOST.
WORKER_SECRET=

# SSH host alias used to fetch the legacy fallback WORKER_SECRET when
# WORKER_SECRET is empty.
# This expects ~/.ssh/config to contain a working cloud-server host alias.
WORKER_SECRET_SSH_HOST=cloudlink-server

# Registered worker id. Dashboard-installed workers are registered automatically.
# For legacy/manual starts, this must match a server-side worker_nodes record.
WORKER_ID=local-worker-1

# Per-request timeout for worker API calls. Keep it below WORKER_ONLINE_SECONDS
# so a stuck HTTPS request does not make the dashboard mark this node offline.
WORKER_API_TIMEOUT_SECONDS=20

# Number of retries for transient worker API failures, such as Cloudflare
# 500/502/503, public HTTPS connection timeouts, SSL EOF, or JSON decode
# failures. Backoff is exponential: base, base*2, base*4, capped by max.
WORKER_API_RETRIES=3

# Base and max backoff seconds between API retries.
WORKER_API_RETRY_BASE_SECONDS=1
WORKER_API_RETRY_MAX_SECONDS=15

# Result artifact uploads use a longer retry window because completed
# computation results are expensive to lose to temporary network/API failures.
CLOUDLINK_ARTIFACT_UPLOAD_RETRIES=6
CLOUDLINK_ARTIFACT_RETRY_BASE_SECONDS=2
CLOUDLINK_ARTIFACT_RETRY_MAX_SECONDS=60

# How often the worker polls for pending tasks when idle.
WORKER_POLL_INTERVAL_SECONDS=5

# How often the worker reports that this node is online.
WORKER_HEARTBEAT_SECONDS=30

# How often idle workers check maintenance endpoints such as dataset delete
# requests. Task claiming always happens before maintenance checks.
WORKER_MAINTENANCE_INTERVAL_SECONDS=60

# Maximum number of tasks this worker may execute at the same time.
# Keep 1 for safest behavior; raise only after checking CPU, memory, and disk headroom.
WORKER_MAX_CONCURRENT_TASKS=1

# Optional scheduler reserve overrides. Leave blank to let Cloudlink reserve
# max(1 CPU core or 20%), max(4GB RAM or 20%), and max(20GB disk or 10%).
# These reserves are subtracted before the cloud-side Codex CLI sees capacity.
# WORKER_RESERVE_DISK_GB is a compatibility shortcut applied to both task and
# dataset disks unless the two dedicated values below are set.
WORKER_RESERVE_CPU_CORES=
WORKER_RESERVE_MEMORY_GB=
WORKER_RESERVE_DISK_GB=
WORKER_RESERVE_JOB_DISK_GB=
WORKER_RESERVE_DATASET_DISK_GB=
WORKER_RESERVE_GPU_MEMORY_GB=

# Task types this local node is willing to execute.
# script_job runs Python scripts generated by the cloud-side Codex CLI.
WORKER_SUPPORTED_TYPES=echo_test,generate_daily_report,script_job

# Cloudlink-only local home. Jobs, virtualenvs, and runtime state live here.
CLOUDLINK_HOME=~/.cloudlink

# Local cache file for WORKER_SECRET. The start script reads this first and only
# falls back to SSH when the cache is missing, so worker startup is not blocked
# by temporary SSH timeouts.
CLOUDLINK_WORKER_SECRET_FILE=~/.cloudlink/worker_secret

# Per-task job folders. Each task gets its own folder with main.py, inputs/, outputs/.
# The console's "任务盘" capacity is measured from this path's filesystem.
CLOUDLINK_JOB_ROOT=~/.cloudlink/jobs

# Parent folder for Cloudlink-managed runtimes.
CLOUDLINK_RUNTIME_ROOT=~/.cloudlink/venvs

# Dedicated Python virtualenv used by script_job. Missing dependencies are installed here.
CLOUDLINK_PYTHON_AUTO_VENV=~/.cloudlink/venvs/python-auto

# Local reusable dataset cache root. Archives and extracted datasets live here.
# The console's "数据盘" capacity is measured from this path's filesystem.
CLOUDLINK_DATASET_ROOT=~/.cloudlink/datasets

# Dataset roots visible to Cloudlink. The first active root receives new
# downloads. Readonly roots stay searchable so old caches remain reusable after
# you add a new data disk. The web console can update this at runtime.
CLOUDLINK_DATASET_ROOTS='[{"path":"~/.cloudlink/datasets","mode":"active","label":"default"}]'

# Timeout for lightweight dataset metadata/cache/delete-request API calls.
CLOUDLINK_DATASET_API_TIMEOUT_SECONDS=20

# Timeout for downloading large dataset archives from the cloud server.
CLOUDLINK_DATASET_DOWNLOAD_TIMEOUT_SECONDS=300

# Base Python used to create the dedicated Cloudlink virtualenv when it does not exist.
CLOUDLINK_BASE_PYTHON=python3

# Allow script_job to install payload requirements into CLOUDLINK_PYTHON_AUTO_VENV.
# Set to 0 only if you want jobs with missing dependencies to fail instead.
CLOUDLINK_AUTO_INSTALL_REQUIREMENTS=1

# Optional Python package index mirror. Leave empty to use pip defaults.
CLOUDLINK_PIP_INDEX_URL=

# Maximum runtime allowed for one script job. Individual jobs can request less.
CLOUDLINK_SCRIPT_MAX_TIMEOUT_SECONDS=3600

# Maximum stdout/stderr bytes kept in the returned task result/logs.
CLOUDLINK_SCRIPT_LOG_LIMIT_BYTES=200000

# Maximum bytes returned for any one file under outputs/.
CLOUDLINK_OUTPUT_FILE_MAX_BYTES=200000

# Maximum total bytes returned across all files under outputs/.
CLOUDLINK_OUTPUT_FILES_MAX_TOTAL_BYTES=800000

# Bytes per retained artifact upload chunk. Larger result files are uploaded in
# resumable chunks and completed with a final sha256 check.
CLOUDLINK_ARTIFACT_CHUNK_BYTES=4194304

# Maximum time allowed for creating the virtualenv.
CLOUDLINK_RUNTIME_SETUP_TIMEOUT_SECONDS=600

# Maximum time allowed for one dependency-install step.
CLOUDLINK_PIP_INSTALL_TIMEOUT_SECONDS=1800
